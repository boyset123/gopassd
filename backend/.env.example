# Copy to backend/.env for local development

MONGODB_URI=mongodb://localhost:27017/gopassdorsu
JWT_SECRET=your_jwt_secret_key_here

# Gmail SMTP — admin user registration sends temporary password emails.
# On Render: set these in Dashboard → Environment (use a Google App Password, not your login password).
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-16-char-app-password

# Firebase admin (JSON string or use serviceAccountKey.json locally)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
