# Copy to backend/.env for local development

MONGODB_URI=mongodb://localhost:27017/gopassdorsu
JWT_SECRET=your_jwt_secret_key_here

# Gmail — same App Password setup that worked before.
EMAIL_USER=your@gmail.com
EMAIL_PASS=your-16-char-app-password

# IMPORTANT: backend/.env is only used when YOU run the server on your PC (npm start).
# The live site on Render does NOT read this file.
# Copy EMAIL_USER and EMAIL_PASS into Render → Dashboard → Environment → Save → Manual Deploy.

# Optional alternative if Gmail times out on Render only:
# RESEND_API_KEY=re_...
# EMAIL_FROM=GoPass DOrSU <noreply@yourdomain.com>

# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
