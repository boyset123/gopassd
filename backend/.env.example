# Copy to backend/.env for local development

MONGODB_URI=mongodb://localhost:27017/gopassdorsu
JWT_SECRET=your_jwt_secret_key_here

# --- Email (pick one approach) ---

# Production on Render: Gmail SMTP — EMAIL_USER + EMAIL_PASS (Google App Password).
# Optional if Gmail ETIMEDOUT on Render: RESEND_API_KEY + EMAIL_FROM (verified domain in Resend).

EMAIL_USER=your@gmail.com
EMAIL_PASS=your-16-char-app-password

# Firebase admin (JSON string or use serviceAccountKey.json locally)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
