# Copy to .env for local development (.env is gitignored)

EXPO_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Local backend (default if unset)
EXPO_PUBLIC_API_BASE_URL=http://192.168.0.247:5000

# Production (Vercel) — your live Render service:
#   EXPO_PUBLIC_API_BASE_URL=https://gopassd.onrender.com
#
# Or leave unset and use vercel.json rewrites (same backend URL).

# Backend email (set on Render, not in this web .env):
#   EMAIL_USER=your@gmail.com
#   EMAIL_PASS=Google App Password (16 chars)
