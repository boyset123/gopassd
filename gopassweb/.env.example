# Copy to .env for local development (.env is gitignored)

EXPO_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Local backend (default if unset)
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

# Production (Vercel):
# Option A — same-origin proxy (default): leave unset; vercel.json rewrites /api to Render.
# Option B — direct backend URL: set in Vercel → Settings → Environment Variables:
#   EXPO_PUBLIC_API_BASE_URL=https://gopassdorsu-api.onrender.com
