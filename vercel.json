{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd gopassweb && npm run build:web",
  "installCommand": "cd gopassweb && npm install",
  "outputDirectory": "gopassweb/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://gopassd.onrender.com/api/:path*"
    },
    {
      "source": "/recaptcha-embed",
      "destination": "https://gopassd.onrender.com/recaptcha-embed"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://gopassd.onrender.com/uploads/:path*"
    }
  ]
}
